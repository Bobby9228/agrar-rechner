# Normalize line endings and treat text as text by default.
* text=auto eol=lf

# Explicitly mark binary files so git does not try to diff or
# normalize them.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp3 binary
*.mp4 binary
*.webm binary

# Source code must always be LF, no matter what the contributor's
# OS does on checkout.
*.js   text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.md   text eol=lf
*.sh   text eol=lf
